{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals"],
    "verbatimModuleSyntax": true,
    "useDefineForClassFields": true
  },
  "include": ["src"],
  "exclude": ["src/sw.ts"]
}
