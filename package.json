{
  "name": "mws-restaurant-stage-1",
  "version": "1.0.0",
  "description": "--- #### _Three Stage Course Material Project - Restaurant Reviews_",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.sw.json && tsc -p tsconfig.node.json && pnpm --filter Restaurant-Reviews typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev:ui": "vite",
    "serve:ui": "tsx ./serve.ts",
    "serve:api": "tsx restaurant-server/app.ts",
    "start:dev": "npm-run-all --parallel dev:ui serve:api",
    "start:prod": "npm-run-all build:ui --parallel serve:api serve:ui",
    "start": "pnpm run start:prod",
    "build:ui": "vite build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bushidocodes/mws-restaurant-stage-1.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bushidocodes/mws-restaurant-stage-1/issues"
  },
  "homepage": "https://github.com/bushidocodes/mws-restaurant-stage-1#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "compression": "^1.7.4",
    "eslint": "^10.5.0",
    "express": "^5.2.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "morgan": "^1.11.0",
    "npm-run-all2": "^9.0.2",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-imagetools": "^10.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "workbox-build": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "leaflet": "^1.9.4",
    "lit-html": "^3.0.0"
  }
