# Copy to `.env`. Every value is optional — the app runs with no config at all.
# This file is shared: Vite reads it for the front-end, and the API loads it too.

# Front-end → API base URL (baked into the client at build time).
API_SERVER=http://localhost:1337

# --- API server (restaurant-server) ---

# Persist data to a SQLite file. Leave unset for an ephemeral in-memory DB
# (re-seeded on every start). Set a path to keep data across restarts.
# DATABASE_PATH=./restaurant-server/data/reviews.db

# Allowed front-end origin(s) for CORS, comma-separated. Leave unset in local
# dev to reflect any origin; set explicitly in production.
CORS_ORIGIN=http://localhost:5173

# Secret used to sign session cookies. Falls back to an insecure dev value when
# unset; set a real value in production.
# SESSION_SECRET=change-me
